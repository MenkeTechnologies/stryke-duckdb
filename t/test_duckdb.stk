## t/test_duckdb.stk — assertion tests for the stryke `DuckDB` package.
##
## Uses stryke's native test framework (`assert_*` + `test_run`).
## Self-contained — DuckDB embeds; no external service needed beyond the
## loaded cdylib (install once with `s pkg install -g .` so stryke's FFI
## bridge dlopens `lib/libstryke_duckdb.{dylib,so}` on `use DuckDB`).

use DuckDB

# ── permission-free: cdylib reachable ───────────────────────────────
val $version = DuckDB::version()
assert_ok $version, "DuckDB::version returns truthy (cdylib loaded)"
assert_ok DuckDB::ping(), "DuckDB::ping returns truthy"

# ── plain SELECT (constants) ────────────────────────────────────────
val @r1 = DuckDB::query("SELECT 1+1 AS two, 'hi' AS s")
assert_eq scalar(@r1), 1, "query const: 1 row"
assert_eq $r1[0]->{two}, 2, "query const: 1+1=2"
assert_eq $r1[0]->{s}, "hi", "query const: string col"

# ── range table-valued function ─────────────────────────────────────
val @r2 = DuckDB::query("SELECT n FROM range(5) AS r(n)")
assert_eq scalar(@r2), 5, "range(5) returns 5 rows"
assert_eq $r2[0]->{n}, 0, "range(5) starts at 0"
assert_eq $r2[4]->{n}, 4, "range(5) ends at 4"

# ── positional bind ─────────────────────────────────────────────────
val @r3 = DuckDB::query("SELECT ?::INT + ?::INT AS r", bind => [10, 32])
assert_eq $r3[0]->{r}, 42, "positional bind: 10+32=42"

# ── query_scalar ────────────────────────────────────────────────────
assert_eq DuckDB::query_scalar("SELECT COUNT(*) FROM range(1000)"), 1000, "query_scalar count"

# ── columnar (wrapper transposes rows→cols, returns {columns, data}) ──
val $cw = DuckDB::query(
    "SELECT id, name FROM (VALUES (1,'a'),(2,'b'),(3,'c')) AS t(id,name)",
    columnar => 1,
)
assert_eq scalar(@{$cw->{columns}}), 2, "columnar: 2 column names"
assert_eq scalar(@{$cw->{data}{id}}), 3, "columnar: id column has 3 vals"
assert_eq $cw->{data}{id}[0], 1, "columnar: id[0]=1"
assert_eq $cw->{data}{name}[2], "c", "columnar: name[2]=c"

# ── file-backed db round-trip ───────────────────────────────────────
val $tmpdb = "/tmp/stryke-duckdb-test-$$.duckdb"
DuckDB::execute("CREATE TABLE t (id INT, name VARCHAR)", db => $tmpdb)
DuckDB::execute("INSERT INTO t VALUES (1,'alice'),(2,'bob'),(3,'charlie')", db => $tmpdb)
assert_eq DuckDB::query_scalar("SELECT COUNT(*) FROM t", db => $tmpdb), 3, "file db: 3 rows inserted"

# ── tables list includes ours ───────────────────────────────────────
val @tlist = DuckDB::tables(db => $tmpdb)
val $found = grep { $_->{name} eq "t" } @tlist
assert_ok $found, "tables: contains 't'"

# ── insert_many + server_version + databases ────────────────────────
val $bs = "stryke_duckdb_bulk_$$"
DuckDB::execute("CREATE TABLE bulk (id INT, name TEXT, score DOUBLE)", session => $bs)
assert_eq DuckDB::insert_many("bulk",
    [{ id => 1, name => "a", score => 1.5 },
     { id => 2, name => "b", score => 2.5 },
     { id => 3, name => "c", score => 3.5 }], session => $bs), 3,
    "insert_many: bulk-inserted 3 rows"
assert_eq DuckDB::count("bulk", undef, session => $bs), 3, "insert_many: count reflects inserts"
assert_ok  DuckDB::exists("bulk", undef, session => $bs), "exists: true when the table has rows"
assert_ok  DuckDB::exists("bulk", "id = 2", session => $bs), "exists: true for a matching WHERE"
assert_ok !DuckDB::exists("bulk", "id = 99", session => $bs), "exists: false for a non-matching WHERE"
assert_eq DuckDB::query_scalar("SELECT name FROM bulk WHERE id = 2", session => $bs), "b",
    "insert_many: column order preserved"
assert_eq DuckDB::insert_many("bulk", [], session => $bs), 0, "insert_many: empty rows is a no-op"
assert_ok DuckDB::server_version(session => $bs) =~ /^v?\d+\./, "server_version: looks like a version"
val @dbs = DuckDB::databases(session => $bs)
assert_ok scalar(grep { $_ eq "memory" } @dbs), "databases: includes the memory catalog"

# ── update + delete (bound SET, interpolated WHERE) — destructive, so
# this runs last on `bulk` after every read above ──────────────────
assert_eq DuckDB::update("bulk", { name => "B", score => 9.0 }, "id = 2", session => $bs), 1,
    "update: one matching row affected"
val $du = DuckDB::query_one("SELECT name, score FROM bulk WHERE id = 2", session => $bs)
assert_eq $du->{name}, "B", "update: SET applied to name"
assert_eq DuckDB::update("bulk", { score => 0.0 }, undef, session => $bs), 3,
    "update: no WHERE touches every row"
assert_eq DuckDB::query_scalar("SELECT sum(score) FROM bulk", session => $bs), 0,
    "update: all scores zeroed"
assert_eq DuckDB::delete("bulk", "id = 1", session => $bs), 1, "delete: one matching row"
assert_eq DuckDB::count("bulk", undef, session => $bs), 2, "delete: count reflects removal"
assert_eq DuckDB::delete("bulk", undef, session => $bs), 2, "delete: no WHERE removes the rest"
assert_eq DuckDB::count("bulk", undef, session => $bs), 0, "delete: table now empty"

# ── upsert: insert, update-on-conflict, DO NOTHING, RETURNING ───────
val $us = "stryke_duckdb_upsert_$$"
DuckDB::execute("CREATE TABLE kv (id INT PRIMARY KEY, name TEXT, hits INT)", session => $us)
assert_eq DuckDB::upsert("kv", { id => 1, name => "a", hits => 1 },
    conflict => ["id"], session => $us), 1, "upsert: insert path affected=1"
DuckDB::upsert("kv", { id => 1, name => "A", hits => 9 }, conflict => ["id"], session => $us)
val $ur = DuckDB::query_one("SELECT name, hits FROM kv WHERE id = 1", session => $us)
assert_eq $ur->{name}, "A", "upsert: default update overwrote name"
assert_eq $ur->{hits}, 9, "upsert: default update overwrote hits"
DuckDB::upsert("kv", { id => 1, name => "ignored", hits => 42 },
    conflict => ["id"], update => ["hits"], session => $us)
val $ur2 = DuckDB::query_one("SELECT name, hits FROM kv WHERE id = 1", session => $us)
assert_eq $ur2->{name}, "A", "upsert: explicit update kept name"
assert_eq $ur2->{hits}, 42, "upsert: explicit update bumped hits"
DuckDB::upsert("kv", { id => 1, name => "nope", hits => 0 },
    conflict => ["id"], update => [], session => $us)
assert_eq DuckDB::query_scalar("SELECT hits FROM kv WHERE id = 1", session => $us), 42,
    "upsert: DO NOTHING left the row unchanged"
val @uret = DuckDB::upsert("kv", { id => 2, name => "b", hits => 5 },
    conflict => ["id"], returning => "id,name", session => $us)
assert_eq scalar(@uret), 1, "upsert RETURNING: 1 row back"
assert_eq $uret[0]->{name}, "b", "upsert RETURNING: row payload"

# ── quote_identifier (pure; safe dynamic-SQL identifier) ─────────────
assert_eq DuckDB::quote_identifier("users"),    q{"users"},      "quote_identifier: wraps a plain name"
assert_eq DuckDB::quote_identifier("my table"), q{"my table"},   "quote_identifier: spaces stay inside the quotes"
assert_eq DuckDB::quote_identifier(q{a"b}),     q{"a""b"},       "quote_identifier: inner double-quote is doubled"
# End to end: a quoted weird column name is valid SQL DuckDB accepts.
val $qs = "quote-test-$$"
DuckDB::execute("CREATE TABLE qt (" . DuckDB::quote_identifier(q{a"b}) . " INTEGER)", session => $qs)
DuckDB::execute("INSERT INTO qt VALUES (7)", session => $qs)
assert_eq DuckDB::query_scalar("SELECT " . DuckDB::quote_identifier(q{a"b}) . " FROM qt", session => $qs), 7,
    "quote_identifier: round-trips a weird identifier through the engine"

# ── index DDL + native catalog introspection ────────────────────────
val $is = "stryke_duckdb_index_$$"
DuckDB::execute("CREATE TABLE widgets (id INT, sku VARCHAR)", session => $is)
val $ci = DuckDB::create_index("idx_widgets_sku", "widgets", ["sku"], unique => 1, session => $is)
assert_eq $ci->{index}, "idx_widgets_sku", "create_index: reports the index name"
val @idx = DuckDB::indexes(session => $is)
assert_ok scalar(grep { $_->{index_name} eq "idx_widgets_sku" } @idx), "indexes: lists the new index"
val $di = DuckDB::drop_index("idx_widgets_sku", session => $is)
assert_eq $di->{dropped}, "idx_widgets_sku", "drop_index: reports the dropped name"
val @idx2 = DuckDB::indexes(session => $is)
assert_ok !scalar(grep { $_->{index_name} eq "idx_widgets_sku" } @idx2), "drop_index: index gone after drop"

# ── table_info (pk flag) + constraints + database_size ───────────────
val $ts = "stryke_duckdb_tinfo_$$"
DuckDB::execute("CREATE TABLE ti (id INT PRIMARY KEY, name VARCHAR)", session => $ts)
val @ti = DuckDB::table_info("ti", session => $ts)
assert_eq scalar(@ti), 2, "table_info: two columns"
val ($idcol) = grep { $_->{name} eq "id" } @ti
assert_ok $idcol->{pk}, "table_info: id column flagged primary key"
val @cons = DuckDB::constraints(session => $ts)
assert_ok scalar(grep { $_->{constraint_type} =~ /PRIMARY KEY/ } @cons), "constraints: PRIMARY KEY surfaced"
val @dsz = DuckDB::database_size(session => $ts)
assert_ok scalar(@dsz) >= 1, "database_size: at least one stats row"

# ── drop (table) round-trip ──────────────────────────────────────────
val $ds = "stryke_duckdb_drop_$$"
DuckDB::execute("CREATE TABLE gone (n INT)", session => $ds)
assert_ok DuckDB::table_exists("gone", session => $ds), "drop: table exists before drop"
DuckDB::drop("gone", session => $ds)
assert_ok !DuckDB::table_exists("gone", session => $ds), "drop: table gone after drop"
val $dn = DuckDB::drop("never_existed", session => $ds)
assert_eq $dn->{dropped}, "never_existed", "drop: if_exists default makes a missing-table drop a no-op success"

# ── appender_columns (column subset; unnamed col takes DEFAULT) ──────
val $as = "stryke_duckdb_appcols_$$"
DuckDB::execute("CREATE TABLE ac (id INT, note VARCHAR DEFAULT 'def')", session => $as)
assert_eq DuckDB::appender_columns("ac", ["id"], [[1],[2],[3]], session => $as), 3,
    "appender_columns: 3 rows appended into the id subset"
assert_eq DuckDB::query_scalar("SELECT note FROM ac WHERE id = 1", session => $as), "def",
    "appender_columns: unnamed column took its DEFAULT"

# ── attach / copy_from / detach (file-backed alias round-trip) ───────
val $attdb = "/tmp/stryke-duckdb-attach-test-$$.duckdb"
val $attcsv = "/tmp/stryke-duckdb-attach-test-$$.csv"
unlink $attdb if -e $attdb
open my $cfh, ">", $attcsv or die "open $attcsv: $!"
print $cfh "id,label\n1,a\n2,b\n3,c\n"
close $cfh
val $ats = "stryke_duckdb_attach_$$"
val $att = DuckDB::attach($attdb, "ext", session => $ats)
assert_eq $att->{alias}, "ext", "attach: reports the alias"
DuckDB::execute("CREATE TABLE ext.loaded (id INT, label VARCHAR)", session => $ats)
val $cf = DuckDB::copy_from("ext.loaded", $attcsv, kind => "csv", session => $ats)
assert_eq $cf->{copied}, 3, "copy_from: 3 CSV rows copied into the attached table"
assert_eq DuckDB::query_scalar("SELECT COUNT(*) FROM ext.loaded", session => $ats), 3,
    "copy_from: rows visible through the attached alias"
val $det = DuckDB::detach("ext", session => $ats)
assert_ok $det->{detached}, "detach: reports success"

# cleanup
unlink $tmpdb if -e $tmpdb
unlink "$tmpdb.wal" if -e "$tmpdb.wal"
unlink $attdb if -e $attdb
unlink "$attdb.wal" if -e "$attdb.wal"
unlink $attcsv if -e $attcsv

test_run
