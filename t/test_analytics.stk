## t/test_analytics.stk — assertion tests for the DuckDB analytics surface
## (v0.4.0): describe/columns/column_types/summarize/head/sample/distinct/
## aggregate/sum_/avg_/min_/max_/group_count/create_table_as/read_parquet/
## copy_to/pragma.
##
## Uses stryke's native test framework (`assert_*` + `test_run`). Self-
## contained — DuckDB embeds; no external service beyond the loaded cdylib
## (install once with `s pkg install -g .`). All helpers route connection
## opts through DuckDB::_conn, so — like the core CRUD helpers — they target a
## named `session =>` rather than a file `db =>`.

use DuckDB

val $s = "stryke_duckdb_analytics_$$"

DuckDB::execute("CREATE TABLE sales (id INT, region TEXT, amount INT)", session => $s)
DuckDB::insert_many("sales", [
    { id => 1, region => "east", amount => 100 },
    { id => 2, region => "east", amount => 200 },
    { id => 3, region => "west", amount => 300 },
    { id => 4, region => "west", amount => 400 },
    { id => 5, region => "west", amount => 500 },
], session => $s)

# ── describe / columns / column_types ────────────────────────────────
val @desc = DuckDB::describe("sales", session => $s)
assert_eq scalar(@desc), 3, "describe: 3 columns"
val @cols = DuckDB::columns("sales", session => $s)
assert_eq scalar(@cols), 3, "columns: 3 names"
assert_ok scalar(grep { $_ eq "amount" } @cols), "columns: includes amount"
val $types = DuckDB::column_types("sales", session => $s)
assert_match qr/(?i)int/, $types->{id}, "column_types: id is an integer type"

# ── summarize ────────────────────────────────────────────────────────
val @summary = DuckDB::summarize("sales", session => $s)
assert_ok scalar(@summary) >= 3, "summarize: at least one stats row per column"

# ── head / sample ────────────────────────────────────────────────────
assert_eq scalar(DuckDB::head("sales", 2, session => $s)), 2, "head: returns N rows"
assert_eq scalar(DuckDB::sample("sales", 3, session => $s)), 3, "sample: returns N rows"

# ── distinct ─────────────────────────────────────────────────────────
val @regions = sort(DuckDB::distinct("sales", "region", session => $s))
assert_eq scalar(@regions), 2, "distinct region: 2 values"
assert_eq $regions[0], "east", "distinct region: east present and sorted first"

# ── aggregates ───────────────────────────────────────────────────────
assert_eq DuckDB::aggregate("sales", "id", "count", undef, session => $s), 5, "aggregate count = 5"
assert_eq DuckDB::sum_("sales", "amount", session => $s), 1500, "sum_ amount = 1500"
assert_eq DuckDB::avg_("sales", "amount", session => $s), 300, "avg_ amount = 300"
assert_eq DuckDB::min_("sales", "amount", session => $s), 100, "min_ amount = 100"
assert_eq DuckDB::max_("sales", "amount", session => $s), 500, "max_ amount = 500"
assert_eq DuckDB::aggregate("sales", "id", "count", "region = 'west'", session => $s), 3,
    "aggregate honors WHERE"

# ── group_count ──────────────────────────────────────────────────────
val @gc = DuckDB::group_count("sales", "region", session => $s)
assert_eq $gc[0]->{value}, "west", "group_count: most frequent first"
assert_eq $gc[0]->{n}, 3, "group_count: west has 3"

# ── create_table_as ──────────────────────────────────────────────────
DuckDB::create_table_as("big", "SELECT * FROM sales WHERE amount >= 300", session => $s)
assert_eq DuckDB::count("big", undef, session => $s), 3, "create_table_as: materialized 3 rows"

# ── copy_to parquet → read_parquet round-trip ────────────────────────
val $pq = "/tmp/stryke-duckdb-analytics-$$.parquet"
DuckDB::copy_to("SELECT * FROM sales ORDER BY id", $pq, format => "parquet", session => $s)
assert_ok -e $pq, "copy_to: parquet file created"
val @back = DuckDB::read_parquet($pq, session => $s)
assert_eq scalar(@back), 5, "read_parquet: 5 rows round-tripped"
assert_eq $back[0]->{id}, 1, "read_parquet: row order preserved"
assert_eq scalar(DuckDB::read_parquet($pq, limit => 2, session => $s)), 2, "read_parquet: limit honored"

# ── pragma ───────────────────────────────────────────────────────────
val @dbl = DuckDB::pragma("database_list", session => $s)
assert_ok scalar(@dbl) >= 1, "pragma database_list: returns rows"

# ── _str_lit escapes embedded quotes (injection guard) ───────────────
assert_eq DuckDB::_str_lit("o'brien"), "'o''brien'", "_str_lit doubles single quotes"

# ── quote_ident / quote_qualified_ident (ANSI double-quote quoting) ──
assert_eq DuckDB::quote_ident("my col"),  "\"my col\"",     "quote_ident: spaces quoted"
assert_eq DuckDB::quote_ident("we\"ird"), "\"we\"\"ird\"",  "quote_ident: embedded quote doubled"
# unquote_ident: inverse of quote_ident (strip quotes, un-double "").
assert_eq DuckDB::unquote_ident("\"my col\""),      "my col",  "unquote_ident: strips the surrounding quotes"
assert_eq DuckDB::unquote_ident("\"we\"\"ird\""),   "we\"ird", "unquote_ident: un-doubles embedded quotes"
assert_eq DuckDB::unquote_ident(DuckDB::quote_ident("a\"b\"c")), "a\"b\"c", "unquote_ident: round-trips quote_ident"
assert_dies fn { DuckDB::unquote_ident("plain") },  "unquote_ident: rejects an unquoted name"
assert_dies fn { DuckDB::unquote_ident("\"a\"b\"") }, "unquote_ident: rejects an unpaired embedded quote"
assert_eq DuckDB::quote_qualified_ident("main.my table"), "\"main\".\"my table\"", "quote_qualified_ident: each segment quoted"
assert_eq DuckDB::quote_qualified_ident("t"), "\"t\"",      "quote_qualified_ident: bare name still quoted"
assert_dies fn { DuckDB::quote_qualified_ident("main.") },  "quote_qualified_ident: rejects empty trailing segment"
assert_dies fn { DuckDB::quote_qualified_ident("a..b") },   "quote_qualified_ident: rejects doubled dot"

# ── quote_literal (value literals: NULL / bare number / quoted string) ──
assert_eq DuckDB::quote_literal("O'Brien"), "'O''Brien'", "quote_literal: string single-quoted, embedded quote doubled"
assert_eq DuckDB::quote_literal(42),        "42",         "quote_literal: number is a bare literal"
assert_eq DuckDB::quote_literal(undef),     "NULL",       "quote_literal: undef is NULL"
assert_eq DuckDB::quote_literal("plain"),   "'plain'",    "quote_literal: plain string quoted"
assert_dies fn { DuckDB::quote_literal([1,2]) }, "quote_literal: rejects a ref"

# unquote_literal: inverse of quote_literal's string form (strip ', un-double '').
assert_eq DuckDB::unquote_literal("'O''Brien'"), "O'Brien", "unquote_literal: un-doubles the embedded quote"
assert_eq DuckDB::unquote_literal("'plain'"),    "plain",   "unquote_literal: plain quoted string"
assert_eq DuckDB::unquote_literal("''"),         "",        "unquote_literal: empty literal"
assert_eq DuckDB::unquote_literal(DuckDB::quote_literal("a'b'c")), "a'b'c", "unquote_literal: round-trips quote_literal"
assert_dies fn { DuckDB::unquote_literal("plain") },   "unquote_literal: rejects an unquoted value"
assert_dies fn { DuckDB::unquote_literal("'a'b'") },   "unquote_literal: rejects an unpaired embedded quote"

# ── quote_like (escape % _ \ for a literal LIKE match) ──
assert_eq DuckDB::quote_like("100%off"), "100\\%off",  "quote_like: % escaped"
assert_eq DuckDB::quote_like("a_b"),     "a\\_b",       "quote_like: _ escaped"
assert_eq DuckDB::quote_like("c:\\p"),   "c:\\\\p",     "quote_like: backslash escaped"
assert_eq DuckDB::quote_like("plain"),   "plain",       "quote_like: ordinary text untouched"
# End to end: a literal "100%off" matches only itself, not "100Xoff" (the % is not a wildcard).
val $pat = DuckDB::quote_literal("%" . DuckDB::quote_like("100%off") . "%")
assert_eq DuckDB::query_scalar("SELECT 'sale 100%off now' LIKE $pat ESCAPE '\\'", session => $s), 1,
    "quote_like: literal % matches itself through the engine"
assert_eq DuckDB::query_scalar("SELECT 'sale 100Xoff now' LIKE $pat ESCAPE '\\'", session => $s), 0,
    "quote_like: escaped % does not act as a wildcard"

# ── unquote_like (inverse of quote_like) ──
assert_eq DuckDB::unquote_like("100\\%off"), "100%off", "unquote_like: escaped % decodes to a literal"
assert_eq DuckDB::unquote_like("a\\_b"),     "a_b",     "unquote_like: escaped _ decodes to a literal"
assert_eq DuckDB::unquote_like("c:\\\\p"),   "c:\\p",   "unquote_like: doubled backslash decodes to one"
assert_eq DuckDB::unquote_like("plain"),     "plain",   "unquote_like: ordinary text untouched"
assert_eq DuckDB::unquote_like(DuckDB::quote_like("50%_off\\sale")), "50%_off\\sale", "unquote_like: round-trips quote_like"
assert_dies fn { DuckDB::unquote_like("a%b") },    "unquote_like: rejects an unescaped wildcard"
assert_dies fn { DuckDB::unquote_like("trail\\") }, "unquote_like: rejects a dangling backslash"

# ── parse_qualified_ident (inverse of quote_qualified_ident) ──
val $segs = DuckDB::parse_qualified_ident("\"main\".\"my table\"")
assert_eq scalar(@$segs), 2,      "parse_qualified_ident: two segments"
assert_eq $segs->[1], "my table", "parse_qualified_ident: quoted segment keeps the space"
assert_eq DuckDB::parse_qualified_ident("\"a.b\".\"c\"")->[0], "a.b", "parse_qualified_ident: dot inside quotes is literal"
assert_eq DuckDB::parse_qualified_ident("\"we\"\"ird\"")->[0], "we\"ird", "parse_qualified_ident: doubled quote decodes to one"
assert_eq DuckDB::parse_qualified_ident("main.users")->[0], "main", "parse_qualified_ident: bare segment passes through"
assert_eq DuckDB::parse_qualified_ident(DuckDB::quote_qualified_ident("main.my table"))->[1], "my table", "parse_qualified_ident: round-trips quote_qualified_ident"
assert_dies fn { DuckDB::parse_qualified_ident("a..b") }, "parse_qualified_ident: rejects an empty segment"
assert_dies fn { DuckDB::parse_qualified_ident("\"unterminated") }, "parse_qualified_ident: rejects an unterminated quote"

# ── format_list (DuckDB list literal) ──
assert_eq DuckDB::format_list(["a", "b", "c"]), "['a', 'b', 'c']",  "format_list: quoted list literal"
assert_eq DuckDB::format_list(["o'brien"]),     "['o''brien']",     "format_list: single quotes doubled per element"
assert_eq DuckDB::format_list([]),              "[]",               "format_list: empty list"
assert_dies fn { DuckDB::format_list("nope") },                     "format_list: rejects non-arrayref"

# ── parse_list (inverse of format_list) ──
assert_eq join("|", @{ DuckDB::parse_list("['a', 'b', 'c']") }), "a|b|c", "parse_list: decodes quoted elements"
assert_eq join("|", @{ DuckDB::parse_list("[1, 2, 3]") }),       "1|2|3", "parse_list: bare numbers"
assert_eq join("|", @{ DuckDB::parse_list(DuckDB::format_list(["o'brien", "a, b"])) }), "o'brien|a, b", "parse_list: round-trips format_list ('' un-doubles, comma-in-quotes literal)"
assert_eq scalar(@{ DuckDB::parse_list("[]") }), 0,                "parse_list: empty list → no elements"
assert_dies fn { DuckDB::parse_list("(1, 2)") },                   "parse_list: rejects a non-[...] wrapper"
assert_dies fn { DuckDB::parse_list("['unterminated]") },          "parse_list: rejects an unterminated quote"

# ── format_in_list (IN-clause operand; mixed types via quote_literal) ──
assert_eq DuckDB::format_in_list([1, 2, 3]),    "(1, 2, 3)",        "format_in_list: bare numbers"
assert_eq DuckDB::format_in_list(["a", q{O'Brien}]), q{('a', 'O''Brien')}, "format_in_list: strings quoted, single-quote doubled"
assert_eq DuckDB::format_in_list([1, "a", undef]), "(1, 'a', NULL)", "format_in_list: mixed number/string/undef"
assert_eq DuckDB::format_in_list([]),           "(NULL)",           "format_in_list: empty → (NULL), matches nothing"
assert_dies fn { DuckDB::format_in_list("nope") },                  "format_in_list: rejects non-arrayref"
# End to end: the built IN-list filters a VALUES table correctly.
assert_eq DuckDB::query_scalar("SELECT count(*) FROM (VALUES (1),(2),(3),(4)) t(x) WHERE x IN " . DuckDB::format_in_list([1, 3])), 2, "format_in_list: filters via a real IN clause"
assert_eq DuckDB::query_scalar("SELECT count(*) FROM (VALUES (1),(2)) t(x) WHERE x IN " . DuckDB::format_in_list([])), 0, "format_in_list: empty (NULL) matches no rows"

# ── parse_in_list (inverse of format_in_list) ──
assert_eq join("|", map { $_ // "<undef>" } @{ DuckDB::parse_in_list("(1, 'a', NULL)") }), "1|a|<undef>", "parse_in_list: number/string/NULL decoded"
assert_eq join("|", @{ DuckDB::parse_in_list(q{('O''Brien', 'a, b')}) }), "O'Brien|a, b", "parse_in_list: '' un-doubles, comma in quotes stays literal"
assert_eq scalar(@{ DuckDB::parse_in_list("()") }), 0, "parse_in_list: empty list → no elements"
assert_eq join("|", map { $_ // "<undef>" } @{ DuckDB::parse_in_list("(NULL)") }), "<undef>", "parse_in_list: (NULL) sentinel → single undef"
# Round-trips format_in_list for the mixed case.
val $rt = [1, q{O'Brien}, undef]
assert_eq join("|", map { $_ // "<undef>" } @{ DuckDB::parse_in_list(DuckDB::format_in_list($rt)) }), "1|O'Brien|<undef>", "parse_in_list: round-trips format_in_list"
assert_dies fn { DuckDB::parse_in_list("1, 2, 3") },     "parse_in_list: rejects un-parenthesized input"
assert_dies fn { DuckDB::parse_in_list("('unterminated)") }, "parse_in_list: rejects an unterminated quote"

# ── format_struct (DuckDB STRUCT literal) ──
assert_eq DuckDB::format_struct(+{ b => "2", a => "1" }), "{'a': '1', 'b': '2'}", "format_struct: keys sorted, struct literal"
assert_eq DuckDB::format_struct(+{ name => "o'brien" }),  "{'name': 'o''brien'}", "format_struct: single quotes doubled in values"
assert_eq DuckDB::format_struct(+{}),                     "{}",                   "format_struct: empty struct"
assert_dies fn { DuckDB::format_struct(["nope"]) },                               "format_struct: rejects non-hashref"

# ── parse_struct (inverse of format_struct) ──
val $ps = DuckDB::parse_struct("{'a': '1', 'b': 'x'}")
assert_eq $ps->{a}, "1",                          "parse_struct: decodes quoted value a"
assert_eq $ps->{b}, "x",                          "parse_struct: decodes quoted value b"
val $rt = DuckDB::parse_struct(DuckDB::format_struct(+{ name => "o'brien", note => "a, b: c" }))
assert_eq $rt->{name}, "o'brien",                 "parse_struct: round-trips format_struct ('' un-doubles)"
assert_eq $rt->{note}, "a, b: c",                 "parse_struct: comma/colon inside quotes stay literal"
assert_eq scalar(keys %{ DuckDB::parse_struct("{}") }), 0, "parse_struct: empty struct → empty hash"
val $bare = DuckDB::parse_struct("{'n': 5, 'z': null}")
assert_eq $bare->{n}, 5,                          "parse_struct: bare number value"
assert_eq defined($bare->{z}), 0,                 "parse_struct: bare null → undef"
assert_dies fn { DuckDB::parse_struct("(x)") },   "parse_struct: rejects a non-{...} wrapper"
assert_dies fn { DuckDB::parse_struct("{'a': 'unterminated}") }, "parse_struct: rejects an unterminated quote"

# ── format_map (DuckDB MAP literal) ──
assert_eq DuckDB::format_map(+{ b => "2", a => "1" }), "MAP {'a': '1', 'b': '2'}", "format_map: MAP keyword + sorted keys"
assert_eq DuckDB::format_map(+{ name => "o'brien" }),  "MAP {'name': 'o''brien'}", "format_map: single quotes doubled in values"
assert_eq DuckDB::format_map(+{}),                     "MAP {}",                   "format_map: empty map"
assert_dies fn { DuckDB::format_map(["nope"]) },                                   "format_map: rejects non-hashref"

# ── parse_map (inverse of format_map) ──
val $pm = DuckDB::parse_map("MAP {'a': '1', 'b': 'x'}")
assert_eq $pm->{a}, "1",                          "parse_map: decodes quoted value a"
assert_eq $pm->{b}, "x",                          "parse_map: decodes quoted value b"
val $pmrt = DuckDB::parse_map(DuckDB::format_map(+{ name => "o'brien", note => "a, b: c" }))
assert_eq $pmrt->{name}, "o'brien",               "parse_map: round-trips format_map ('' un-doubles)"
assert_eq $pmrt->{note}, "a, b: c",               "parse_map: comma/colon inside quotes stay literal"
assert_eq scalar(keys %{ DuckDB::parse_map("MAP {}") }), 0, "parse_map: empty map → empty hash"
assert_eq scalar(keys %{ DuckDB::parse_map("{'k': '1'}") }), 1, "parse_map: MAP keyword is optional"
val $pmbare = DuckDB::parse_map("MAP {'n': 5, 'z': null}")
assert_eq $pmbare->{n}, 5,                         "parse_map: bare number value"
assert_eq defined($pmbare->{z}), 0,               "parse_map: bare null → undef"
assert_dies fn { DuckDB::parse_map("(x)") },      "parse_map: rejects a non-{...} wrapper"
assert_dies fn { DuckDB::parse_map("MAP {'a': 'unterminated}") }, "parse_map: rejects an unterminated quote"

# cleanup
unlink $pq if -e $pq

test_run
