## t/test_stryke_duckdb_surface.stk — wrapper-completeness pin.
##
## Asserts every public `fn X::Y::name` declared in lib/*.stk is
## reachable via `use` at runtime. Uses `exists &X::Y::name` to
## probe the symbol table without invoking the sub.
##
## Catches:
##   * a wrapper sub deleted from lib/ but still referenced elsewhere
##   * a sub-package file dropped from the install layout
##   * `use Foo::Bar` failing to chase into lib/Bar.stk
##   * an installed-package entry whose namespace bridge is broken
##
## Permission-free — no service, no creds, no live daemon. Private
## helpers (`_` prefix) are implementation detail and are NOT
## asserted, so refactoring internals stays free.

use DuckDB

# ── DuckDB.stk ──────────────────────────────────────────────
assert_ok exists &DuckDB::version, "DuckDB::version exists"
assert_ok exists &DuckDB::ping, "DuckDB::ping exists"
assert_ok exists &DuckDB::inspect, "DuckDB::inspect exists"
assert_ok exists &DuckDB::server_version, "DuckDB::server_version exists"
assert_ok exists &DuckDB::query, "DuckDB::query exists"
assert_ok exists &DuckDB::query_stream, "DuckDB::query_stream exists"
assert_ok exists &DuckDB::query_one, "DuckDB::query_one exists"
assert_ok exists &DuckDB::query_col, "DuckDB::query_col exists"
assert_ok exists &DuckDB::query_scalar, "DuckDB::query_scalar exists"
assert_ok exists &DuckDB::dump, "DuckDB::dump exists"
assert_ok exists &DuckDB::execute, "DuckDB::execute exists"
assert_ok exists &DuckDB::exec_file, "DuckDB::exec_file exists"
assert_ok exists &DuckDB::insert_many, "DuckDB::insert_many exists"
assert_ok exists &DuckDB::appender, "DuckDB::appender exists"
assert_ok exists &DuckDB::explain, "DuckDB::explain exists"
assert_ok exists &DuckDB::import, "DuckDB::import exists"
assert_ok exists &DuckDB::export, "DuckDB::export exists"
assert_ok exists &DuckDB::tables, "DuckDB::tables exists"
assert_ok exists &DuckDB::databases, "DuckDB::databases exists"
assert_ok exists &DuckDB::schema, "DuckDB::schema exists"
assert_ok exists &DuckDB::begin, "DuckDB::begin exists"
assert_ok exists &DuckDB::commit, "DuckDB::commit exists"
assert_ok exists &DuckDB::rollback, "DuckDB::rollback exists"
assert_ok exists &DuckDB::transaction, "DuckDB::transaction exists"
assert_ok exists &DuckDB::count, "DuckDB::count exists"
assert_ok exists &DuckDB::table_exists, "DuckDB::table_exists exists"
assert_ok exists &DuckDB::exists, "DuckDB::exists exists"
assert_ok exists &DuckDB::update, "DuckDB::update exists"
assert_ok exists &DuckDB::delete, "DuckDB::delete exists"
assert_ok exists &DuckDB::truncate, "DuckDB::truncate exists"
assert_ok exists &DuckDB::upsert, "DuckDB::upsert exists"

# ── DuckDB.stk catalog introspection ──
assert_ok exists &DuckDB::views, "DuckDB::views exists"
assert_ok exists &DuckDB::functions, "DuckDB::functions exists"
assert_ok exists &DuckDB::settings, "DuckDB::settings exists"
assert_ok exists &DuckDB::extensions, "DuckDB::extensions exists"

# ── pure SQL-quoting helpers ──
assert_ok exists &DuckDB::quote_ident, "DuckDB::quote_ident exists"
assert_ok exists &DuckDB::quote_literal, "DuckDB::quote_literal exists"
assert_ok exists &DuckDB::quote_qualified_ident, "DuckDB::quote_qualified_ident exists"
assert_ok exists &DuckDB::parse_qualified_ident, "DuckDB::parse_qualified_ident exists"
assert_ok exists &DuckDB::format_list, "DuckDB::format_list exists"
assert_ok exists &DuckDB::format_struct, "DuckDB::format_struct exists"
assert_ok exists &DuckDB::format_map, "DuckDB::format_map exists"

test_run
