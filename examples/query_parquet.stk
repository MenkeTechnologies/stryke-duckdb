#!/usr/bin/env stryke
# examples/query_parquet.stk — query a parquet file with SQL, no import.
# Run:   s examples/query_parquet.stk /path/to/file.parquet

use DuckDB

val $path = $ARGV[0]
die "usage: query_parquet.stk PATH.parquet\n" unless defined $path
die "not found: $path\n" unless -e $path

p "row count:"
p DuckDB::query_scalar("SELECT COUNT(*) FROM '$path'")

p "\nfirst 5 rows (any schema):"
val @rows = DuckDB::query("SELECT * FROM '$path' LIMIT 5")
for val $r (@rows) {
    p to_json $r
}

p "\nschema:"
val @cols = DuckDB::query("DESCRIBE SELECT * FROM '$path'")
for val $c (@cols) {
    p sprintf("  %-30s %s", $c->{column_name}, $c->{column_type})
}
